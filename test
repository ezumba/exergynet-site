<script>
(function verifyProgramStatus() {
  var statusElement = document.getElementById("program-status");
  var badgeElement = document.getElementById("program-status-badge");

  if (!statusElement) return;

  fetch("https://api.mainnet-beta.solana.com", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      jsonrpc: "2.0",
      id: 1,
      method: "getAccountInfo",
      params: [
        "Fe8KhdiFWhKcPWH2N2Svqc3VSpK9EzN8nMh9pQ3cPCeD",
        {
          encoding: "base64"
        }
      ]
    })
  })
    .then(function(response) {
      return response.json();
    })
    .then(function(data) {
      var value = data && data.result && data.result.value;

      if (value && value.executable === true) {
        statusElement.textContent = "Program executable on Solana Mainnet-Beta.";
        if (badgeElement) badgeElement.textContent = "ONLINE";
      } else if (value) {
        statusElement.textContent = "Program account found, but executable status was not confirmed.";
        if (badgeElement) badgeElement.textContent = "CHECK";
      } else {
        statusElement.textContent = "Program account could not be verified from public RPC.";
        if (badgeElement) badgeElement.textContent = "UNVERIFIED";
      }
    })
    .catch(function() {
      statusElement.textContent = "Program status unavailable from public RPC.";
      if (badgeElement) badgeElement.textContent = "RPC UNAVAILABLE";
    });
})();
</script>

