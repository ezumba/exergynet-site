async function joinRecursiveBatch() {
  const client = new LnesM2MClient({
    network: "mainnet-beta",
    aggregatorUrl: "https://aggregator.exergynet.org"
  });

  const inputData = {
    task: "autonomous-sorting",
    entropy_threshold: 0.25
  };

  const childProof = await client.generateChildProof({
    input: inputData,
    guest: "exergy_guest_v3"
  });

  const submission = await client.submitChildProof({
    proof: childProof,
    feeBid: 0.50,
    settlementProgram: "Fe8KhdiFWhKcPWH2N2Svqc3VSpK9EzN8nMh9pQ3cPCeD"
  });

  console.log("Batch submission:", submission.jobId);
}</code></pre>

