# biological_proxy environment variables
# Copy this to .env and fill in your values

PORT=5000

# PostgreSQL — use Unix socket path for peer auth (no password needed)
PGHOST=/var/run/postgresql
PGPORT=5432
PGDATABASE=biological_proxy
PGUSER=ubuntu
# PGPASSWORD=  # Leave unset for peer auth via Unix socket

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change-me-with-openssl-rand-hex-32

# Stripe (optional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=

# Portal URL (for CORS / redirects)
PORTAL_URL=https://portal.exergynet.org
